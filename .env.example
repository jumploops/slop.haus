# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slophaus
# Optional drizzle-kit SSL mode override for migrations (e.g., require, verify-full)
DRIZZLE_SSL_MODE=

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_SECRET=generate-a-random-string-here

# Firecrawl
FIRECRAWL_API_KEY=

# Anthropic (for LLM moderation)
ANTHROPIC_API_KEY=

# Storage (MVP uses local filesystem)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=http://localhost:3001/uploads

# Storage (S3)
S3_BUCKET=
S3_REGION=us-east-1
# Optional: custom S3-compatible endpoint (e.g., MinIO/R2). If set, path-style is used.
S3_ENDPOINT=
# Optional: explicit public base URL for objects (overrides endpoint/region default)
S3_PUBLIC_URL=
# AWS credentials (or provide via instance role/secret manager)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: only needed for temporary credentials (STS/assumed roles)
AWS_SESSION_TOKEN=

# Worker
WORKER_POLL_INTERVAL_MS=5000

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Chrome / performance tooling
# Override CHROME_BIN on non-macOS machines if Chrome lives elsewhere.
CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Dedicated project-local Chrome profile root used by perf tooling.
CHROME_USER_DATA_DIR=.chrome/slop-haus
# Optional: keep a stable DevTools port for later tracing/automation.
CHROME_REMOTE_DEBUGGING_PORT=9222
# Default landing URL when launching the project Chrome profile.
CHROME_START_URL=http://localhost:3000/

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Cookie consent banner (web)
# Set to false/0 to disable banner logic entirely
NEXT_PUBLIC_COOKIE_BANNER_ENABLED=true
# Emergency kill switch: force banner globally regardless of geo
NEXT_PUBLIC_COOKIE_BANNER_FORCE_GLOBAL=false
# Bump when consent text/policy materially changes
NEXT_PUBLIC_COOKIE_BANNER_POLICY_VERSION=2026-02-27
