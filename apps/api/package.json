{
  "name": "@slop/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- tsx src/index.ts",
    "start:prod": "tsx src/index.ts",
    "start:dist": "dotenv -e ../../.env -- node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@hono/node-server": "^1.13.7",
    "better-auth": "^1.2.3",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.6.16",
    "tsx": "^4.19.2",
    "@slop/db": "workspace:*",
    "@slop/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.7.2"
  }
}
